<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.6.xsd">

    <changeSet id="001-regions" author="raj">
        <createTable tableName="regions">
            <column name="id" type="INT" autoIncrement="true">
                <constraints primaryKey="true"/>
            </column>
            <column name="code" type="VARCHAR(100)">
                <constraints unique="true" nullable="false"/>
            </column>
            <column name="island" type="VARCHAR(100)"/>
            <column name="region_en" type="VARCHAR(100)"/>
            <column name="region_fr" type="VARCHAR(100)"/>
            <column name="region_km" type="VARCHAR(100)"/>
            <column name="created_at" type="TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>
        <addUniqueConstraint tableName="regions" columnNames="island, region_en" constraintName="uq_regions_name_en"/>
        <addUniqueConstraint tableName="regions" columnNames="island, region_fr" constraintName="uq_regions_name_fr"/>
        <addUniqueConstraint tableName="regions" columnNames="island, region_km" constraintName="uq_regions_name_km"/>
    </changeSet>

    <!-- ISLANDS -->
    <changeSet id="002-islands" author="raj">
        <createTable tableName="islands">
            <column name="id" type="INT" autoIncrement="true">
                <constraints primaryKey="true"/>
            </column>
            <column name="code" type="VARCHAR(100)">
                <constraints unique="true" nullable="false"/>
            </column>
            <column name="name_en" type="VARCHAR(100)"/>
            <column name="name_fr" type="VARCHAR(100)"/>
            <column name="name_km" type="VARCHAR(100)"/>
            <column name="created_at" type="TIMESTAMP"/>
        </createTable>
        <addUniqueConstraint tableName="islands" columnNames="name_en" constraintName="uq_islands_name_en"/>
        <addUniqueConstraint tableName="islands" columnNames=" name_fr" constraintName="uq_islands_name_fr"/>
        <addUniqueConstraint tableName="islands" columnNames=" name_km" constraintName="uq_islands_name_km"/>
    </changeSet>

    <!-- USERS -->
    <changeSet id="003-users" author="raj">
        <createTable tableName="users">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true"/>
            </column>
            <column name="user_id" type="VARCHAR(100)">
                <constraints unique="true" nullable="false"/>
            </column>
            <column name="user_type" type="VARCHAR(50)"/>
            <column name="full_name" type="VARCHAR(100)"/>
            <column name="mobile_no" type="VARCHAR(100)">
                <constraints unique="true"/>
            </column>
            <column name="email" type="VARCHAR(100)">
                <constraints unique="true"/>
            </column>
            <column name="island" type="VARCHAR(100)"/>
            <column name="region" type="VARCHAR(100)"/>
            <column name="status" type="VARCHAR(50)"/>
            <column name="registration_stage" type="VARCHAR(100)"/>
            <column name="managed_by_type" type="VARCHAR(50)"/>
            <column name="managed_by_id" type="VARCHAR(100)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="session_token" type="VARCHAR(64)"/>
            <column name="created_at" type="TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP"/>
            <column name="last_login" type="VARCHAR(100)"/>
            <column name="verified_by_admin" type="VARCHAR(20)"/>
            <column name="admin_id" type="VARCHAR(100)"/>
            <column name="verified_by_adjudicator" type="VARCHAR(20)"/>
            <column name="adjudicator_id" type="VARCHAR(100)"/>
            <column name="fcm_token" type="VARCHAR(200)"/>
            <column name="rejected_reason" type="VARCHAR(100)"/>
            <column name="verified_at" type="TIMESTAMP"/>
            <column name="preferred_language" type="VARCHAR(5)"/>
        </createTable>

        <addForeignKeyConstraint baseTableName="users"
                                 baseColumnNames="region"
                                 referencedTableName="regions"
                                 referencedColumnNames="code"
                                 constraintName="fk_users_region"/>
    </changeSet>

    <!-- USER CREDENTIALS -->
    <changeSet id="004-user-credentials" author="raj">
        <createTable tableName="user_credentials">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true"/>
            </column>
            <column name="user_id" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="password" type="VARCHAR(255)"/>
            <column name="pin_hash" type="VARCHAR(255)"/>
            <column name="password_algo" type="VARCHAR(100)"/>
            <column name="pin_algo" type="VARCHAR(100)"/>
            <column name="salt" type="VARCHAR(255)"/>
            <column name="password_updated_at" type="VARCHAR(100)"/>
            <column name="pin_updated_at" type="VARCHAR(100)"/>
            <column name="failed_attempts" type="VARCHAR(100)"/>
            <column name="locked_until" type="VARCHAR(100)"/>
            <column name="created_at" type="TIMESTAMP"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="updated_at" type="TIMESTAMP"/>

        </createTable>
        <addForeignKeyConstraint baseTableName="user_credentials"
                                 baseColumnNames="user_id"
                                 referencedTableName="users"
                                 referencedColumnNames="user_id"
                                 constraintName="fk_user_credentials"/>
    </changeSet>

    <!-- USER DOCUMENTS -->
    <changeSet id="005-user-documents" author="raj">
        <createTable tableName="user_documents">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true"/>
            </column>
            <column name="document_id" type="VARCHAR(100)"/>
            <column name="user_id" type="VARCHAR(100)"/>
            <column name="document_type" type="VARCHAR(50)"/>
            <column name="document_number" type="TEXT"/>
            <column name="document_url" type="VARCHAR(255)"/>
            <column name="verification_status" type="VARCHAR(255)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="verified_by" type="VARCHAR(100)"/>
            <column name="verified_at" type="TIMESTAMP"/>
            <column name="created_at" type="TIMESTAMP"/>
        </createTable>
        <addForeignKeyConstraint baseTableName="user_documents"
                                 baseColumnNames="user_id"
                                 referencedTableName="users"
                                 referencedColumnNames="user_id"
                                 constraintName="fk_user_documents"/>

    </changeSet>

    <!-- SESSION LOG -->
    <changeSet id="006-session-log" author="raj">
        <createTable tableName="session_log">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true"/>
            </column>
            <column name="user_id" type="VARCHAR(100)"/>
            <column name="session_token" type="VARCHAR(64)"/>
            <column name="ip_address" type="VARCHAR(45)"/>
            <column name="user_agent" type="VARCHAR(500)"/>
            <column name="login_at" type="TIMESTAMP"/>
            <column name="logout_at" type="TIMESTAMP"/>
            <column name="logout_type" type="VARCHAR(20)"/>
            <column name="duration_seconds" type="INT"/>
            <column name="created_at" type="TIMESTAMP"/>
        </createTable>
        <addForeignKeyConstraint baseTableName="session_log"
                                 baseColumnNames="user_id"
                                 referencedTableName="users"
                                 referencedColumnNames="user_id"
                                 constraintName="fk_session_user"/>
    </changeSet>

    <!-- REFRESH TOKENS -->
    <changeSet id="007-refresh-tokens" author="raj">
        <createTable tableName="refresh_tokens">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true"/>
            </column>
            <column name="user_id" type="VARCHAR(100)"/>
            <column name="token_hash" type="CHAR(64)"/>
            <column name="expires_at" type="TIMESTAMP"/>
            <column name="revoked" type="BOOLEAN"/>
            <column name="created_at" type="TIMESTAMP"/>
            <column name="replaced_by" type="CHAR(64)"/>
            <column name="last_used_at" type="TIMESTAMP"/>
            <column name="ip" type="VARCHAR(45)"/>
            <column name="user_agent" type="VARCHAR(255)"/>
        </createTable>
        <addForeignKeyConstraint baseTableName="refresh_tokens"
                                 baseColumnNames="user_id"
                                 referencedTableName="users"
                                 referencedColumnNames="user_id"
                                 constraintName="fk_refresh_users"/>
    </changeSet>

    <!-- OTP-CHALLENGES -->
    <changeSet id="008-otp-challenges" author="raj">
        <createTable tableName="otp_challenges">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true"/>
            </column>
            <column name="otp_id" type="VARCHAR(100)"/>
            <column name="user_id" type="VARCHAR(100)"/>
            <column name="otp" type="VARCHAR(100)"/>
            <column name="purpose" type="VARCHAR(50)"/>
            <column name="otp_hash" type="VARCHAR(100)"/>
            <column name="attempts" type="VARCHAR(100)"/>
            <column name="verified" type="VARCHAR(100)"/>
            <column name="expires_at" type="TIMESTAMP"/>
            <column name="created_at" type="TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>
        <addForeignKeyConstraint baseTableName="otp_challenges"
                                 baseColumnNames="user_id"
                                 referencedTableName="users"
                                 referencedColumnNames="user_id"
                                 constraintName="fk_otp_user"/>
    </changeSet>

    <!-- SECURITY EVENTS -->
    <changeSet id="009-security-event-log" author="raj">
        <createTable tableName="security_event_log">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true"/>
            </column>
            <column name="user_id" type="VARCHAR(100)"/>
            <column name="event_type" type="VARCHAR(50)"/>
            <column name="identifier" type="VARCHAR(100)"/>
            <column name="ip_address" type="VARCHAR(45)"/>
            <column name="user_agent" type="VARCHAR(500)"/>
            <column name="trace_id" type="VARCHAR(64)"/>
            <column name="created_at" type="TIMESTAMP"/>
        </createTable>
        <addForeignKeyConstraint baseTableName="security_event_log"
                                 baseColumnNames="user_id"
                                 referencedTableName="users"
                                 referencedColumnNames="user_id"
                                 constraintName="fk_security_user"/>
    </changeSet>

    <!-- NOTIFICATIONS -->
    <changeSet id="010-notifications" author="raj">
        <createTable tableName="notifications">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true"/>
            </column>
            <column name="notification_id" type="VARCHAR(100)"/>
            <column name="source_id" type="VARCHAR(100)"/>
            <column name="target_id" type="VARCHAR(100)"/>
            <column name="payment_mode" type="VARCHAR(100)"/>
            <column name="type" type="VARCHAR(100)"/>
            <column name="notification_type" type="VARCHAR(64)"/>
            <column name="dealer_id" type="VARCHAR(100)"/>
            <column name="receiver_id" type="VARCHAR(100)"/>
            <column name="super_dealer_id" type="VARCHAR(100)"/>
            <column name="partner_agent_id" type="VARCHAR(100)"/>
            <column name="island" type="VARCHAR(100)"/>
            <column name="workflow_status" type="VARCHAR(100)"/>
            <column name="amount_collected" type="DECIMAL(18,2)"/>
            <column name="pay_request_id" type="VARCHAR(100)"/>
            <column name="collection_request_id" type="VARCHAR(100)"/>
            <column name="created_at" type="TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>
        <addForeignKeyConstraint baseTableName="notifications"
                                 baseColumnNames="dealer_id"
                                 referencedTableName="users"
                                 referencedColumnNames="user_id"
                                 constraintName="fk_notif_dealer"/>
        <addForeignKeyConstraint baseTableName="notifications"
                                 baseColumnNames="receiver_id"
                                 referencedTableName="users"
                                 referencedColumnNames="user_id"
                                 constraintName="fk_notif_receiver"/>
        <addForeignKeyConstraint baseTableName="notifications"
                                 baseColumnNames="super_dealer_id"
                                 referencedTableName="users"
                                 referencedColumnNames="user_id"
                                 constraintName="fk_notif_sd"/>
        <addForeignKeyConstraint baseTableName="notifications"
                                 baseColumnNames="source_id"
                                 referencedTableName="users"
                                 referencedColumnNames="user_id"
                                 constraintName="fk_notif_source"/>
        <addForeignKeyConstraint baseTableName="notifications"
                                 baseColumnNames="target_id"
                                 referencedTableName="users"
                                 referencedColumnNames="user_id"
                                 constraintName="fk_notif_target"/>
        <addForeignKeyConstraint baseTableName="notifications"
                                 baseColumnNames="partner_agent_id"
                                 referencedTableName="users"
                                 referencedColumnNames="user_id"
                                 constraintName="fk_notif_pa"/>
    </changeSet>

    <!-- I18N-MESSAGES -->
    <changeSet id="011-i18n-messages" author="raj">
        <createTable tableName="i18n_messages">
            <column name="message_key" type="VARCHAR(100)">
                <constraints primaryKey="true"/>
            </column>
            <column name="language" type="VARCHAR(10)">
                <constraints primaryKey="true"/>
            </column>
            <column name="message" type="CLOB"/>
        </createTable>
    </changeSet>

    <!-- EMAIL TEMPLATE -->
    <changeSet id="012-email-template" author="raj">
        <createTable tableName="email_templates">
            <column name="template_key" type="VARCHAR(100)">
                <constraints primaryKey="true"/>
            </column>
            <column name="language" type="VARCHAR(5)">
                <constraints primaryKey="true"/>
            </column>
            <column name="description" type="VARCHAR(255)"/>
            <column name="subject" type="VARCHAR(255)"/>
            <column name="body" type="TEXT"/>
            <column name="is_active" type="TINYINT(1)"/>
            <column name="updated_by" type="VARCHAR(100)"/>
            <column name="updated_at" type="TIMESTAMP"/>
            <column name="created_at" type="TIMESTAMP"/>
        </createTable>
    </changeSet>

    <!-- SMS TEMPLATE -->
    <changeSet id="013-sms-template" author="raj">
        <createTable tableName="sms_templates">
            <column name="template_key" type="VARCHAR(100)">
                <constraints primaryKey="true"/>
            </column>
            <column name="language" type="VARCHAR(5)">
                <constraints primaryKey="true"/>
            </column>
            <column name="description" type="VARCHAR(255)"/>
            <column name="body" type="TEXT"/>
            <column name="is_active" type="TINYINT(1)"/>
            <column name="updated_by" type="VARCHAR(100)"/>
            <column name="updated_at" type="TIMESTAMP"/>
            <column name="created_at" type="TIMESTAMP"/>
        </createTable>
    </changeSet>

    <!-- RATE LIMIT -->
    <changeSet id="014-rate-limit" author="raj">
        <createTable tableName="rate_limits">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true"/>
            </column>
            <column name="endpoint" type="VARCHAR(100)"/>
            <column name="key_type" type="VARCHAR(50)"/>
            <column name="key_value" type="VARCHAR(255)"/>
            <column name="created_at" type="TIMESTAMP"/>
        </createTable>
    </changeSet>

    <!-- TRANSACTIONS -->
    <changeSet id="021-transactions" author="raj">
        <createTable tableName="transactions">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true"/>
            </column>
            <column name="txn_id" type="VARCHAR(255)">
                <constraints unique="true"/>
            </column>
            <column name="txn_category" type="VARCHAR(50)"/>
            <column name="txn_type" type="VARCHAR(50)"/>
            <column name="channel" type="VARCHAR(50)"/>
            <column name="initiated_by" type="VARCHAR(255)"/>
            <column name="source_user_id" type="VARCHAR(255)"/>
            <column name="target_user_id" type="VARCHAR(255)"/>
            <column name="amount" type="DECIMAL(18,2)"/>
            <column name="remarks" type="VARCHAR(255)"/>
            <column name="status" type="VARCHAR(255)"/>
            <column name="batch_id" type="VARCHAR(255)"/>
            <column name="created_at" type="TIMESTAMP"/>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="transactions"
                baseColumnNames="initiated_by"
                constraintName="fk_txn_initiated"
                referencedTableName="users"
                referencedColumnNames="user_id"/>

        <addForeignKeyConstraint
                baseTableName="transactions"
                baseColumnNames="source_user_id"
                constraintName="fk_txn_source"
                referencedTableName="users"
                referencedColumnNames="user_id"/>

        <addForeignKeyConstraint
                baseTableName="transactions"
                baseColumnNames="target_user_id"
                constraintName="fk_txn_target"
                referencedTableName="users"
                referencedColumnNames="user_id"/>
    </changeSet>

    <!-- TRANSACTION-DISPUTES  -->
    <changeSet id="015-transaction-disputes" author="raj">
        <createTable tableName="transaction_disputes">
            <column name="dispute_id" type="VARCHAR(100)">
            <constraints primaryKey="true"/>
            </column>
            <column name="txn_id" type="VARCHAR(100)"/>
            <column name="raised_by" type="VARCHAR(100)"/>
            <column name="reason" type="CLOB"/>
            <column name="status" type="VARCHAR(20)"/>
            <column name="resolved_by" type="VARCHAR(100)"/>
            <column name="resolution" type="TEXT"/>
            <column name="updated_at" type="TIMESTAMP"/>
            <column name="created_at" type="TIMESTAMP"/>
        </createTable>

        <addForeignKeyConstraint baseTableName="transaction_disputes"
                                 baseColumnNames="txn_id"
                                 referencedTableName="transactions"
                                 referencedColumnNames="txn_id"
                                 constraintName="fk_dispute_txn"/>
        <addForeignKeyConstraint baseTableName="transaction_disputes"
                                 baseColumnNames="raised_by"
                                 referencedTableName="users"
                                 referencedColumnNames="user_id"
                                 constraintName="fk_dispute_raised"/>
        <addForeignKeyConstraint baseTableName="transaction_disputes"
                                 baseColumnNames="resolved_by"
                                 referencedTableName="users"
                                 referencedColumnNames="user_id"
                                 constraintName="fk_dispute_resolved"/>
    </changeSet>

    <!-- SECURITY DEPOSITS -->
    <changeSet id="016-security-deposits" author="raj">
        <createTable tableName="security_deposits">
            <column name="id" type="BIGINT" autoIncrement="true"><constraints primaryKey="true"/></column>
            <column name="code" type="VARCHAR(100)"/>
            <column name="type_of_dealer" type="VARCHAR(100)"/>
            <column name="description" type="VARCHAR(100)"/>
            <column name="status" type="VARCHAR(100)"/>
            <column name="created_at" type="TIMESTAMP"/>
        </createTable>
    </changeSet>


    <!-- USER-ATTRIBUTES -->
    <changeSet id="017-user-attributes" author="raj">
        <createTable tableName="user_attributes">
            <column name="id" type="BIGINT" autoIncrement="true"><constraints primaryKey="true"/></column>
            <column name="attribute_id" type="VARCHAR(100)"/>
            <column name="user_id" type="VARCHAR(100)"/>
            <column name="attribute_key" type="VARCHAR(100)"/>
            <column name="attribute_value" type="VARCHAR(100)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="created_at" type="TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>
        <addForeignKeyConstraint baseTableName="user_attributes"
                                 baseColumnNames="user_id"
                                 referencedTableName="users"
                                 referencedColumnNames="user_id"
                                 constraintName="fk_user_attributes"/>
    </changeSet>


    <!-- ADMIN-ACTION-LOG -->
    <changeSet id="018-admin_action_log" author="raj">
        <createTable tableName="admin_action_log">
            <column name="id" type="BIGINT" autoIncrement="true"><constraints primaryKey="true"/></column>
            <column name="performed_by" type="VARCHAR(100)"/>
            <column name="action_type" type="VARCHAR(50)"/>
            <column name="target_user_id" type="VARCHAR(50)"/>
            <column name="details" type="CLOB"/>
            <column name="ip_address" type="VARCHAR(45)"/>
            <column name="created_at" type="TIMESTAMP"/>
        </createTable>
    </changeSet>


    <!-- PLATFORM-ACCOUNT -->
    <changeSet id="019-platform_account" author="raj">
        <createTable tableName="platform_account">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true"/>
            </column>
            <column name="platform_id" type="VARCHAR(100)"/>
            <column name="account_code" type="VARCHAR(100)"/>
            <column name="balance" type="DECIMAL(18,2)"/>
            <column name="description" type="VARCHAR(100)"/>
            <column name="status" type="VARCHAR(100)"/>
            <column name="created_at" type="TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>

    </changeSet>

</databaseChangeLog>