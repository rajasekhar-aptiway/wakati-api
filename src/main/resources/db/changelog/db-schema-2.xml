                baseColumnNames="to_id"
                constraintName="fk_cash_txn_to"
                referencedTableName="users"
                referencedColumnNames="user_id"/>
    </changeSet>

    <!-- 37 -->
    <changeSet id="037-dealer_type_financial_config" author="raj">
        <createTable tableName="dealer_type_financial_config">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true"/>
            </column>
            <column name="dealer_type_id" type="VARCHAR(255)"/>
            <column name="security_deposit" type="DECIMAL(18,2)"/>
            <column name="deposit_min_limit" type="DECIMAL(18,2)"/>
            <column name="deposit_max_limit" type="DECIMAL(18,2)"/>
            <column name="withdrawal_min_limit" type="DECIMAL(18,2)"/>
            <column name="withdrawal_max_limit" type="DECIMAL(18,2)"/>
            <column name="minimum_opening_balance" type="DECIMAL(18,2)"/>
            <column name="created_at" type="TIMESTAMP"/>
            <column name="daily_deposit_limit" type="DECIMAL(18,2)"/>
            <column name="daily_withdrawal_limit" type="DECIMAL(18,2)"/>
        </createTable>

    </changeSet>

</databaseChangeLog>